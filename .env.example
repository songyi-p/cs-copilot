# Server-only OpenAI credentials. Copy this file to `.env.local` and fill in the key.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.4-nano.
OPENAI_MODEL=gpt-5.4-nano

# Pooled PostgreSQL URL for Next.js application traffic.
DATABASE_URL=

# Direct PostgreSQL URL for Prisma migrations and seed.
DIRECT_URL=

# Generate with: npx auth secret --copy
AUTH_SECRET=

# Recommended for Vercel and other trusted reverse proxies.
AUTH_TRUST_HOST=true
